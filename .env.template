# =====================================================================
# BrokeLLM — API Keys
# =====================================================================
# Copy to .env and fill in the keys for providers you want to use.
# Unused keys can be left as-is — they're only loaded when a backend
# that needs them is selected via `broke swap`.
#
#   cp .env.template .env
#
# WARNING: .env contains secrets. Do NOT commit it.
# =====================================================================

# Optional local gateway security overrides. If unset, BrokeLLM generates
# local tokens automatically and stores them in restricted local files.
# BROKE_CLIENT_TOKEN=
# BROKE_INTERNAL_MASTER_KEY=

# OpenRouter — free tier models (:free suffix)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXX
# Optional extra keys for rotation on provider rate limits:
# OPENROUTER_API_KEY_2=sk-or-v1-XXXXX
# OPENROUTER_API_KEY_3=sk-or-v1-XXXXX

# Groq — fast inference, free tier
# https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXX
# GROQ_API_KEY_2=gsk_XXXXX

# Cerebras — low-latency inference, free tier
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-XXXXX
# CEREBRAS_API_KEY_2=csk-XXXXX

# GitHub — PAT with Models permission (free tier)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_XXXXX
# GITHUB_TOKEN_2=ghp_XXXXX

# Google Gemini — free tier via AI Studio
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaXXXXX
# GEMINI_API_KEY_2=AIzaXXXXX

# Hugging Face — user access token (free serverless inference)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_XXXXX
# HF_TOKEN_2=hf_XXXXX
